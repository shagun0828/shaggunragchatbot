# Environment Variables for Phase 4.3 Multi-Model Processing System
# Copy this file to .env and fill in your actual API keys and configuration

# =============================================================================
# CHROMA CLOUD CONFIGURATION
# =============================================================================
# Get your API key from https://trychroma.com
CHROMA_API_KEY=your_chroma_cloud_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=mutual-funds-db
CHROMA_HOST=https://api.trychroma.com

# =============================================================================
# SENTENCE TRANSFORMERS CONFIGURATION
# =============================================================================
# Hugging Face API key (optional, for downloading models)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Model cache directory (optional, defaults to ~/.cache/huggingface)
TRANSFORMERS_CACHE=/path/to/model/cache

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
# Webhook URL for notifications (optional)
NOTIFICATION_WEBHOOK=your_webhook_url_here

# Email notification settings (optional)
EMAIL_NOTIFICATIONS=false
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here
NOTIFICATION_EMAIL=your_notification_email_here

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (optional, defaults to console only)
LOG_FILE=/path/to/log/file.log

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Maximum concurrent processing threads
MAX_CONCURRENT_THREADS=4

# Batch processing size
DEFAULT_BATCH_SIZE=32

# Memory limit in MB
MEMORY_LIMIT_MB=4096

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Debug mode (true/false)
DEBUG_MODE=false

# Enable profiling (true/false)
ENABLE_PROFILING=false

# Mock external services for testing (true/false)
MOCK_EXTERNAL_SERVICES=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT secret for API authentication (if using API endpoints)
JWT_SECRET=your_jwt_secret_key_here

# API rate limiting
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Prometheus metrics endpoint (optional)
METRICS_PORT=9090
ENABLE_METRICS=false

# Health check endpoint configuration
HEALTH_CHECK_PORT=8080
ENABLE_HEALTH_CHECK=true

# =============================================================================
# DATABASE CONFIGURATION (if using local database)
# =============================================================================
# Local database connection (optional)
DATABASE_URL=sqlite:///./data/multi_model.db

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Redis configuration (optional, for distributed caching)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# =============================================================================
# EXTERNAL API CONFIGURATION
# =============================================================================
# Financial data API keys (optional)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Test environment flag
TESTING=false

# Test data directory
TEST_DATA_DIR=./tests/data

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Docker environment
DOCKER_ENV=false
CONTAINER_NAME=multi-model-processor

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# Production environment flag
PRODUCTION=false

# SSL certificate path (if using HTTPS)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================
# Add any custom environment variables here
CUSTOM_VAR=custom_value_here
